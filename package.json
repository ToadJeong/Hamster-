{
  "name": "hamster-community",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=@hamster/web",
    "dev:mobile": "npm run start --workspace=@hamster/mobile",
    "build:web": "npm run build --workspace=@hamster/web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=18.17"
  }
}
