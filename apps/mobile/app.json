{
  "expo": {
    "name": "햄찌랜드",
    "slug": "hamster-community",
    "scheme": "hamster",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.hamster.community" },
